{
  "schema_version": "3.1",
  "units": "mm",
  "_comment": "Schema sample with NEUTRAL placeholder names — every layer, block and keyword below is an example; real values always come from the customer's own DXF via the intake form. $ref: a {\"$ref\": \"#/zones/<name>\"} node resolves to that entry in the shared 'zones' catalog; sibling keys override.",

  "io": {
    "input_dxf": "",
    "output_dir": ""
  },

  "zones": {
    "WetRoom":   { "identifier": "balloon",  "keyword": "ROOM LABEL TEXT", "text_layer": "TEXT-LAYER", "boundaries": ["WALL-LAYER-1", "OPENING-SPAN-LAYER"] },
    "FrontArea": { "identifier": "polyline", "layer": "FRONT-AREA-OUTLINE-LAYER" },
    "BackRoom":  { "identifier": "balloon",  "keyword": "ANOTHER ROOM LABEL" },
    "SalesArea": { "identifier": "polyline", "layer": "SALES-OUTLINE-LAYER" },
    "DeskZone":  { "identifier": "block",    "blockname": "DESK-BLOCK-NAME" },
    "StoreRoom": { "identifier": "polyline", "layer": "STORE-ROOM-OUTLINE-LAYER" }
  },

  "flooring_types": [
    { "name": "Tile600", "kind": "tile", "length_mm": 600, "width_mm": 600, "rotation_deg": 45 },
    { "name": "WoodHatch", "kind": "hatch", "pattern": "AR-PARQ1", "scale": 10, "angle": 0, "color": 30 },
    { "name": "NoFloor", "kind": "skip" }
  ],
  "default_flooring_type": "Tile600",

  "flooring": {
    "store_outline": { "layers": ["STORE-OUTLINE-LAYER"] },
    "zones": [
      { "zone": { "$ref": "#/zones/WetRoom" },  "flooring_type": "NoFloor" },
      { "zone": { "$ref": "#/zones/SalesArea" }, "flooring_type": "WoodHatch" }
    ],
    "wall_frame": {
      "mirror_layers": ["WALL-LAYER-1", "WALL-HATCH-LAYER", "PARTITION-LAYER"],
      "hatch_layers": [],
      "hatch_scale": 10
    }
  },

  "speaker": {
    "docket": "speaker",
    "enabled": true,
    "mode": "placement",
    "model": {
      "speaker_size_mm": 300,
      "coverage_radius_mm": 4000,
      "box_width_mm": 400,
      "box_height_mm": 200
    },
    "placements": [
      { "target": { "$ref": "#/zones/FrontArea" }, "position": "corners", "count": null },
      { "target": { "$ref": "#/zones/WetRoom" },   "position": "center",  "count": 1 },
      { "target": "store",                          "position": "auto",    "count": null }
    ],
    "boxes": [
      { "target": { "$ref": "#/zones/DeskZone" }, "position": "center", "count": 1 }
    ]
  },

  "sprinkler": {
    "docket": "sprinkler",
    "enabled": true,
    "model": {
      "coverage_radius_mm": 2300,
      "max_spacing_mm": 3700,
      "pattern": "square",
      "coverage": "full"
    },
    "target": "store",
    "min_one_per_room": true,
    "rooms": [ { "$ref": "#/zones/WetRoom" }, { "$ref": "#/zones/BackRoom" } ]
  },

  "partition": {
    "docket": "partition",
    "enabled": true,
    "keep": {
      "boundary":   ["STORE-OUTLINE-LAYER", "LEASE-LINE-LAYER"],
      "structural": ["WALL-LAYER-1", "COLUMN-LAYER", "BEAM-LAYER"],
      "partitions": ["PARTITION-LAYER", "CURTAIN-LAYER", "SHUTTER-LAYER"],
      "text":       ["TEXT-LAYER"]
    },
    "style": [
      { "zone": { "$ref": "#/zones/StoreRoom" }, "color_aci": 1, "lineweight": 50, "label_area": true },
      { "zone": { "$ref": "#/zones/SalesArea" }, "color_aci": 3, "lineweight": 35, "label_area": false }
    ],
    "label_layer": "SYSTEM_LABELS"
  },

  "electrical": {
    "docket": "electrical",
    "enabled": true,
    "groups": [
      { "match": ["WALL-FIXTURE-BLOCK*", "MIRROR-BLOCK*"], "place": "wall",      "label": "WP1", "note": "6A RAW POINT @2250MM" },
      { "match": ["SCREEN-BLOCK*"],                        "place": "ceiling",   "label": "CP1", "note": "6/16A SOCKET + CAT6 IN CEILING" },
      { "match": ["COUNTER-BLOCK*", "DESK-BLOCK-NAME"],    "place": "floor",     "label": "FP1", "note": "6/16A RAW IN FLOOR" },
      { "match": ["DESK-BLOCK-NAME"],                      "place": "data",      "label": "CT1", "note": "3-CONDUIT FLOOR BOX (DATA/UPS/16A)" },
      { "match": ["GAS-POINT-BLOCK"],                      "place": "Gas point", "label": "GP1", "note": "1/2\" GAS CONNECTION" }
    ]
  },

  "finishes": {
    "docket": "finishes",
    "enabled": true,
    "materials": [
      { "name": "Paint",  "applies_to": [ {"$ref":"#/zones/BackRoom"}, {"$ref":"#/zones/DeskZone"} ], "height_mm": 2400, "color_aci": 5 },
      { "name": "Tile",   "applies_to": [ {"$ref":"#/zones/WetRoom"} ],                               "height_mm": 2100, "color_aci": 6 },
      { "name": "Mirror", "applies_to": [ "MIRROR-LINE-LAYER" ],                                      "height_mm": 2325, "color_aci": 133 }
    ]
  },

  "skirting": {
    "docket": "skirting",
    "enabled": true,
    "zones": [ { "$ref": "#/zones/FrontArea" }, { "$ref": "#/zones/BackRoom" } ],
    "exclude": [ { "$ref": "#/zones/WetRoom" } ],
    "height_mm": 100,
    "measure": "length"
  }
}
